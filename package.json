{
  "name": "inventory-Manager",
  "version": "0.1.0",
  "private": true,
  "author": "VNE Digital",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "prisma": "prisma",
    "predist": "cmd /c \"taskkill /IM InventoryManager.exe /F >nul 2>&1 || exit /b 0\"",
    "prepare:electron-prisma": "node electron/sync-prisma-alias.js",
    "dist": "npm run build && npm run prepare:electron-prisma && electron-builder -w"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.469.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.53.0",
    "sonner": "^1.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^30.0.0",
    "electron-builder": "^25.0.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.inventory.desktop",
    "productName": "InventoryManager",
    "icon": "app/favicon.ico",
    "files": [
      ".next/**/*",
      "node_modules/@prisma/client/**/*",
      "node_modules/.prisma/client/**/*",
      "node_modules/@prisma/client-*/**/*",
      "public/**/*",
      "electron/main.js",
      "electron/sync-prisma-alias.js",
      "license/public.pem",
      "package.json",
      "prisma/**/*",
      "settings.json"
    ],
    "asarUnpack": [
      "node_modules/.prisma/client/**/*",
      "license/public.pem",
      "public.pem"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "prisma/dev.db",
        "to": "dev.db",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "license/public.pem",
        "to": "license/public.pem",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "license/public.pem",
        "to": "public.pem",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/.prisma/client",
        "to": "prisma-client",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "InventoryManager-${version}.exe",
      "icon": "app/favicon.ico"
    }
  },
  "description": "Inventory Manager desktop app with licensing"
}
